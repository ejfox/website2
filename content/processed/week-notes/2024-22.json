le=\"background-color:#222222;background-image:url(&#x22;data:image/jpeg;base64,&#x22;);background-size:cover;background-position:center;--splay-rot:-2.18deg;\" width=\"2024\" height=\"2474\" data-dimensions=\"2024×2474\" class=\"img-full my-8 rounded-sm img-splay aspect-[3/4] w-full mx-auto py-4\" crossorigin=\"anonymous\"><figcaption class=\"\">Task management app showing today's to-do list with 2 new items including workout outfit, ceramics, and studio livestream calendar tasks.</figcaption></figure><p class=\"\"></p>",
