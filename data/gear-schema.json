{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gear Item",
  "description": "Schema for gear.csv items - LighterPack-compatible with extended metadata",
  "type": "object",
  "properties": {
    "Name": { "type": "string", "description": "Item name (required)" },
    "Weight_oz": { "type": "number", "description": "Weight in ounces" },
    "Parent Container": { "type": "string", "description": "Physical bag/container this item lives inside (empty if top-level or not currently packed). NOT a status — use Status for archived/home-base/modular." },
    "Status": { "type": "string", "enum": ["Active", "Archived", "HomeBase", "Modular"], "default": "Active", "description": "Lifecycle/location tier, independent of physical container. Active=in rotation; Archived=retired/broken/replaced; HomeBase=kept at home, not in EDC; Modular=swappable kit staged for trips." },
    "Type": { "type": "string", "enum": ["Bag", "Tech", "Utility", "Comfort", "Sleep", "Food", "Safety", "Creativity"] },
    "Category": { "type": "string", "enum": ["Adventure", "Personal", "Tech", "Creative"] },
    "Subcategory": { "type": "string" },
    "Priority": { "type": "string", "enum": ["High", "Medium", "Low", "Optional"] },
    "Waterproof": { "type": "string", "enum": ["Yes", "No"] },
    "Worn": { "type": "string", "enum": ["Yes", "No"], "description": "LighterPack: worn weight" },
    "Qty": { "type": "integer", "minimum": 1, "default": 1, "description": "LighterPack: quantity" },
    "Consumable": { "type": "string", "enum": ["Yes", "No"], "description": "LighterPack: food/water/fuel" },
    "Star": { "type": "string", "enum": ["Yes", "No"], "description": "LighterPack: Big 3 / key items" },
    "Notes": { "type": "string", "description": "Free-form notes" },
    "Tags": { "type": "string", "description": "Semicolon-separated tags" },
    "Condition": { "type": "string", "enum": ["New", "Good", "Fair", "Poor", "Needs Repair"] },
    "Amazon_URL": { "type": "string", "format": "uri" },
    "Last_Used": { "type": "string", "format": "date" },
    "Purchase_Date": { "type": "string", "format": "date" },
    "Purchase_Price": { "type": "number" },
    "Photo_URL": { "type": "string", "format": "uri" },
    "Scan_3D_URL": { "type": "string", "format": "uri" },
    "Serial_Number": { "type": "string" },
    "Model_Number": { "type": "string" },
    "Brand": { "type": "string" },
    "Location_Room": { "type": "string" },
    "Location_Detail": { "type": "string" }
  },
  "required": ["Name"],
  "additionalProperties": false
}
